{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "pnpm --filter @workspace/piodev run build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @workspace/piodev run serve",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
